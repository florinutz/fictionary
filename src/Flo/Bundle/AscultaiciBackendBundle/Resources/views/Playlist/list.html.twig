{% extends '::ascultaici.html.twig' %}

{% block body -%}
    <h1>Playlists</h1>

    <style>
        .records_list td, .records_list th {
            padding: 10px 20px;
        }
    </style>

    <table class="records_list">
        <thead>
            <tr>
                <th>Title</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for entity in entities %}
            <tr>
                <td><a href="{{ path('ascultaici_playlist_show', { 'slug': entity.slug }) }}">{{ entity.title }}</a></td>
                <td>{% if entity.createdAt %}{{ entity.createdAt|date('Y-m-d H:i') }}{% endif %}</td>
                <td>
                    <a href="{{ path('ascultaici_playlist_edit', { 'slug': entity.slug }) }}">edit</a>,
                    <a href="{{ path('ascultaici_playlist_delete', { 'slug': entity.slug }) }}">delete</a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

        <ul>
        <li>
            <a href="{{ path('ascultaici_playlist_new') }}">Create a new one</a>
        </li>
    </ul>
{% endblock %}
