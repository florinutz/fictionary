{% extends '::ascultaici.html.twig' %}

{% block body -%}
    <h1>Playlist edit</h1>

    {{ form(edit_form) }}

    <ul class="record_actions">
    <li>
        <a href="{{ path('ascultaici_track_new', {playlist: entity.id}) }}">
            Add a track
