{% extends '::base.html.twig' %}

{% block body -%}
    <h1>Fictiuni</h1>

    {% for entity in entities %}
    <div id="fiction-{{ entity.id }}">
        <a href="{{ path('flo_fictionary_front_show', {'id': entity.id}) }}">{{ entity.name }}</a>
        <p>{{ entity.description }}</p>
    </div>
    {% endfor %}
{% endblock %}
